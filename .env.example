# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# AZURE AD - COUNSELOR AUTHENTICATION
# ============================================
# Get these from: Azure Portal → App Registrations → Your App → Overview
NEXT_PUBLIC_AZURE_CLIENT_ID=your-azure-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=your-azure-tenant-id
NEXT_PUBLIC_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
# Redirect URI for counselor popup login. Add this exact URL in Azure App Registration → Authentication → Redirect URIs.
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000/counselor/login/popup
# Azure AD group Object IDs: users in these groups can sign in as counselor. Get from Azure Portal → Groups → [group] → Overview → Object ID.
SOULVYNS_COUNSELORS_GROUP_ID=your-soulvyns-counselors-group-object-id
SOULVYNS_ADMIN_GROUP_ID=your-soulvyns-admin-group-object-id

# ============================================
# MICROSOFT GRAPH API (Server-Side Only)
# ============================================
# Get these from: Azure Portal → App Registrations → Your App
# GRAPH_TENANT_ID and GRAPH_CLIENT_ID are the same as above
# GRAPH_CLIENT_SECRET: Certificates & secrets → Create new secret
GRAPH_TENANT_ID=your-azure-tenant-id
GRAPH_CLIENT_ID=your-azure-client-id
GRAPH_CLIENT_SECRET=your-graph-client-secret
# Test seed uses admin@soulvyns.co.za as Teams organizer (ms_graph_user_email); ensure this user exists in your tenant.
# If you get "Insufficient privileges": add app permissions (OnlineMeetings.ReadWrite.All, User.Read.All) and an application access policy – see docs/GRAPH_TEAMS_SETUP.md

# ============================================
# PAYFAST PAYMENT GATEWAY
# ============================================
# Get these from: PayFast Dashboard → Settings → Integration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase-optional
PAYFAST_ENV=sandbox

# ============================================
# AZURE EMAIL (soulvyns-email)
# ============================================
# Booking confirmation emails to client + counselor. Get from Azure Portal:
# - soulvyns-comms (or soulvyns-email) → Keys → Connection string
# - soulvyns-email → Provision domains → use verified domain (e.g. donotreply@soulvyns.co.za)
AZURE_COMMUNICATION_CONNECTION_STRING=your-connection-string
AZURE_EMAIL_FROM=DoNotReply@soulvyns.co.za

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Base URL for the app. PayFast return/cancel/notify URLs are built from this:
#   return_url = {NEXT_PUBLIC_BASE_URL}/bookings/success
#   cancel_url = {NEXT_PUBLIC_BASE_URL}/bookings/cancel
#   notify_url = {NEXT_PUBLIC_BASE_URL}/api/payfast/notify
# Local: http://localhost:3000  |  Ngrok: https://your-subdomain.ngrok-free.app  |  Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
